      "parameters": {
        "chatId": "859474045",
        "text": "=🚨 *ALERTA DE INCIDENTE*\n\n🌐 Serviço: {{$node[\"🕒 Enriquecer Evento de Incidente\"].json[\"servico\"]}}\n\n📌 Tipo: {{$node[\"🕒 Enriquecer Evento de Incidente\"].json[\"tipo\"]}}\n⚠️ Severidade: {{$node[\"🕒 Enriquecer Evento de Incidente\"].json[\"severidade\"]}}\n\n📝 Descrição:\n{{$node[\"🕒 Enriquecer Evento de Incidente\"].json[\"mensagem\"]}}\n\n📅 Data: {{$node[\"🕒 Enriquecer Evento de Incidente\"].json[\"data\"]}}\n🕒 Hora: {{$node[\"🕒 Enriquecer Evento de Incidente\"].json[\"hora\"]}}\n\n🔔 Notificação automática enviada via Telegram",
        "additionalFields": {
          "appendAttribution": false
        }
