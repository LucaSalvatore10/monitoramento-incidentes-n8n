    {
      "parameters": {
        "jsCode": "const ultimaLinha = $input.first().json;\n\nconst dataIncidente = ultimaLinha.ultimaDataHora;\n\n// Converte:\n// 10/06/2026 18:48:02\nconst [dataParte, horaParte] = dataIncidente.split(' ');\nconst [dia, mes, ano] = dataParte.split('/');\n\nconst dataInicio = new Date(\n  `${ano}-${mes}-${dia}T${horaParte}`\n);\n\nconst agora = new Date();\n\nconst diferencaMs = agora - dataInicio;\n\nconst duracaoMinutos = Math.floor(\n  diferencaMs / (1000 * 60)\n);\n\nconst data = agora.toLocaleDateString('pt-BR');\nconst hora = agora.toLocaleTimeString('pt-BR');\n\nreturn [\n  {\n    tipo: \"Recuperação\",\n    severidade: \"Baixa\",\n    mensagem: \"Serviço recuperado com sucesso\",\n    servico: ultimaLinha.servico,\n\n    data: data,\n    hora: hora,\n\n    evento: \"RECUPERACAO\",\n\n    duracaoMinutos: duracaoMinutos,\n    tempoIndisponibilidade: duracaoMinutos\n  }\n];"
      },
